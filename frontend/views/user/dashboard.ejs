<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GymBro • User Dashboard</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Booking Modal -->
  <div id="booking-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white border-4 border-primary shadow-[8px_8px_0px_0px_#296374] w-full max-w-md max-h-[90vh] overflow-y-auto">
        <div class="bg-primary text-contrast p-4 flex justify-between items-center border-b-4 border-accent">
            <h3 class="text-xl font-extrabold uppercase tracking-tighter">Book New Session</h3>
            <button id="close-booking-modal" class="hover:text-accent"><i data-lucide="x" class="w-6 h-6"></i></button>
        </div>
        <div class="p-6">
            <form id="booking-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-bold uppercase mb-1">Date</label>
                    <input type="date" id="book-date" required class="w-full p-3 border-2 border-primary bg-contrast focus:outline-none focus:border-accent font-bold">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold uppercase mb-1">Start Time</label>
                        <input type="time" id="book-time" required class="w-full p-3 border-2 border-primary bg-contrast focus:outline-none focus:border-accent font-bold">
                    </div>
                    <div>
                        <label class="block text-sm font-bold uppercase mb-1">Duration</label>
                        <select id="book-duration" class="w-full p-3 border-2 border-primary bg-contrast focus:outline-none focus:border-accent font-bold">
                            <option value="60">1 Hour</option>
                            <option value="90">1.5 Hours</option>
                            <option value="120">2 Hours</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-bold uppercase mb-1">Select Trainer</label>
                    <select id="book-trainer" required class="w-full p-3 border-2 border-primary bg-contrast focus:outline-none focus:border-accent font-bold">
                        <option value="">Loading...</option>
                    </select>
                    <p id="trainer-status" class="text-xs text-red-500 font-bold mt-1 hidden">Trainer not available</p>
                </div>
                <div>
                    <label class="block text-sm font-bold uppercase mb-1">Select Equipment</label>
                    <select id="book-equipment" required class="w-full p-3 border-2 border-primary bg-contrast focus:outline-none focus:border-accent font-bold">
                        <option value="">Loading...</option>
                    </select>
                    <p id="equipment-status" class="text-xs text-red-500 font-bold mt-1 hidden">Equipment not available</p>
                </div>
                
                <div class="pt-4 flex justify-end gap-4">
                    <button type="button" id="cancel-booking" class="px-6 py-3 font-bold uppercase text-primary hover:bg-gray-100 transition-colors">Cancel</button>
                    <button type="submit" class="bg-primary text-contrast px-6 py-3 font-bold uppercase hover:bg-secondary hover:shadow-[4px_4px_0px_0px_#629FAD] transition-all active:translate-y-1 active:shadow-none border-2 border-transparent">
                        Confirm Booking
                    </button>
                </div>
            </form>
        </div>
    </div>
  </div>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#0C2C55',
            secondary: '#296374',
            accent: '#629FAD',
            contrast: '#EDEDCE',
            dark: {
                bg: '#0F0F0F',
                card: '#232D3F',
                primary: '#005B41',
                accent: '#008170',
                text: '#EDEDCE'
            }
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          borderRadius: {
            DEFAULT: '0px',
            'none': '0px',
            'sm': '0px',
            'md': '0px',
            'lg': '0px',
            'xl': '0px',
            '2xl': '0px',
            '3xl': '0px',
            'full': '0px',
          }
        }
      }
    }
  </script>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body { font-family: 'Inter', sans-serif; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #EDEDCE; }
    ::-webkit-scrollbar-thumb { background: #296374; }
    ::-webkit-scrollbar-thumb:hover { background: #0C2C55; }
  </style>
  <script src="/js/theme.js"></script>
</head>
<body class="bg-contrast text-primary min-h-screen flex overflow-hidden dark:bg-dark-bg dark:text-dark-text transition-colors duration-300">

  <!-- Sidebar -->
  <aside class="w-64 bg-primary text-contrast flex-shrink-0 flex flex-col border-r-4 border-accent hidden md:flex">
    <div class="h-20 flex items-center justify-center border-b border-secondary">
      <h1 class="text-3xl font-extrabold tracking-tighter uppercase italic">Gym<span class="text-accent">Bro</span></h1>
    </div>

    <nav class="flex-1 overflow-y-auto py-6">
      <ul class="space-y-1">
        <li>
          <a href="/user/dashboard" class="flex items-center gap-4 px-6 py-4 bg-secondary border-l-4 border-accent text-white font-bold uppercase tracking-wide transition-all">
            <i data-lucide="calendar" class="w-5 h-5"></i>
            <span>Schedule</span>
          </a>
        </li>
        <li>
          <a href="/user/profile" class="flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="user" class="w-5 h-5 group-hover:text-accent transition-colors"></i>
            <span>My Profile</span>
          </a>
        </li>
        <li class="mt-8 border-t border-secondary pt-4">
          <button onclick="logout()" class="w-full text-left flex items-center gap-4 px-6 py-4 text-red-300 hover:bg-red-900/50 hover:text-red-100 font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="log-out" class="w-5 h-5 group-hover:text-red-400 transition-colors"></i>
            <span>Logout</span>
          </button>
          <button onclick="toggleTheme()" class="w-full text-left flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i id="theme-icon" data-lucide="moon" class="w-5 h-5 group-hover:text-accent transition-colors"></i>
            <span>Theme</span>
          </button>
        </li>
      </ul>
    </nav>

    <!-- User Profile Footer -->
    <div class="p-4 bg-secondary border-t border-primary">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-accent flex items-center justify-center text-primary font-bold text-lg rounded-none">
          ME
        </div>
        <div>
          <p class="text-sm font-bold text-white user-name-display">Loading...</p>
          <p class="text-xs text-accent user-role-display">Member</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
    
    <!-- Mobile Header -->
    <header class="h-16 bg-primary text-contrast flex items-center justify-between px-4 md:hidden shadow-lg z-10">
      <button id="mobile-menu-btn" class="p-2 hover:bg-secondary text-white">
        <i data-lucide="menu" class="w-6 h-6"></i>
      </button>
      <span class="font-bold uppercase tracking-wider">My Dashboard</span>
      <div class="w-8"></div>
    </header>

    <!-- Mobile Sidebar -->
    <div id="mobile-sidebar" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden md:hidden">
      <aside class="w-64 h-full bg-primary text-contrast flex flex-col border-r-4 border-accent shadow-2xl transform -translate-x-full transition-transform duration-300" id="mobile-sidebar-content">
        <div class="h-16 flex items-center justify-between px-6 border-b border-secondary">
          <h1 class="text-2xl font-extrabold uppercase italic">Gym<span class="text-accent">Bro</span></h1>
          <button id="close-sidebar-btn" class="text-white hover:text-accent">
            <i data-lucide="x" class="w-6 h-6"></i>
          </button>
        </div>
        <nav class="flex-1 overflow-y-auto py-4">
          <ul class="space-y-1">
            <li><a href="/user/dashboard" class="block px-6 py-3 bg-secondary text-white font-bold uppercase border-l-4 border-accent">Schedule</a></li>
            <li><a href="/user/profile" class="block px-6 py-3 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase">My Profile</a></li>
            <li><button onclick="logout()" class="block w-full text-left px-6 py-3 text-red-300 hover:bg-red-900/50 hover:text-red-100 font-semibold uppercase">Logout</button></li>
          </ul>
        </nav>
      </aside>
    </div>

    <!-- Content Area -->
    <div class="flex-1 overflow-y-auto p-4 md:p-8 bg-contrast relative dark:bg-dark-bg">
      
      <!-- Page Header -->
      <div class="mb-8 border-b-4 border-primary pb-4 flex flex-col md:flex-row md:items-end justify-between gap-4 dark:border-dark-primary">
        <div>
          <h2 class="text-4xl font-extrabold text-primary uppercase tracking-tighter dark:text-dark-text">
            Gym Schedule
          </h2>
          <p class="text-secondary font-medium mt-1 dark:text-dark-accent">
            Check availability and your upcoming sessions.
          </p>
        </div>
        <button id="btn-book-session" class="bg-primary text-contrast px-6 py-3 font-bold uppercase hover:bg-secondary hover:shadow-[4px_4px_0px_0px_#629FAD] transition-all active:translate-y-1 active:shadow-none border-2 border-transparent flex items-center gap-2 dark:bg-dark-primary dark:text-white dark:hover:bg-dark-accent">
            <i data-lucide="plus-circle" class="w-5 h-5"></i>
            Book Session
        </button>
      </div>

      <!-- Schedule Table -->
      <div class="bg-white border-2 border-primary shadow-[8px_8px_0px_0px_#296374] dark:bg-dark-card dark:border-dark-primary">
        <div class="bg-secondary p-4 flex justify-between items-center border-b-2 border-primary dark:bg-dark-primary dark:border-dark-accent">
          <h3 class="text-xl font-bold text-white uppercase tracking-wider flex items-center gap-2">
            <i data-lucide="calendar-days" class="w-5 h-5 text-accent dark:text-dark-text"></i>
            All Bookings
          </h3>
          <span class="text-xs font-bold text-accent bg-primary px-2 py-1 uppercase dark:bg-dark-bg dark:text-dark-accent">Read Only</span>
        </div>
        
        <div class="p-0 overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-gray-100 border-b-2 border-primary text-primary text-sm uppercase tracking-wider dark:bg-dark-bg dark:text-dark-text dark:border-dark-primary">
                <th class="p-4 font-extrabold">Time</th>
                <th class="p-4 font-extrabold">Activity/Equipment</th>
                <th class="p-4 font-extrabold">Trainer</th>
                <th class="p-4 font-extrabold text-center">Status</th>
              </tr>
            </thead>
            <tbody id="schedule-table-body" class="divide-y-2 divide-gray-100 text-sm font-semibold text-secondary dark:text-gray-300 dark:divide-dark-primary">
              <tr>
                <td colspan="4" class="p-4 text-center">Loading schedule...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>

  <script>
    lucide.createIcons();
    
    // Sidebar Logic
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const closeSidebarBtn = document.getElementById('close-sidebar-btn');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const mobileSidebarContent = document.getElementById('mobile-sidebar-content');

    function openSidebar() {
      mobileSidebar.classList.remove('hidden');
      setTimeout(() => mobileSidebarContent.classList.remove('-translate-x-full'), 10);
    }

    function closeSidebar() {
      mobileSidebarContent.classList.add('-translate-x-full');
      setTimeout(() => mobileSidebar.classList.add('hidden'), 300);
    }

    if(mobileMenuBtn) mobileMenuBtn.addEventListener('click', openSidebar);
    if(closeSidebarBtn) closeSidebarBtn.addEventListener('click', closeSidebar);
    if(mobileSidebar) mobileSidebar.addEventListener('click', (e) => {
      if (e.target === mobileSidebar) closeSidebar();
    });
  </script>
  
  <script src="/js/config.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/user/dashboard.js"></script>
</body>
</html>
