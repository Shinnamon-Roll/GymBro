<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GymBro • Customers</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#0C2C55',
            secondary: '#296374',
            accent: '#629FAD',
            contrast: '#EDEDCE',
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          borderRadius: {
            DEFAULT: '0px',
            'none': '0px',
            'sm': '0px',
            'md': '0px',
            'lg': '0px',
            'xl': '0px',
            '2xl': '0px',
            '3xl': '0px',
            'full': '0px',
          }
        }
      }
    }
  </script>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body { font-family: 'Inter', sans-serif; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #EDEDCE; }
    ::-webkit-scrollbar-thumb { background: #296374; }
    ::-webkit-scrollbar-thumb:hover { background: #0C2C55; }
    
    /* Scrollbar โหมดมืด */
    .dark ::-webkit-scrollbar-track { background: #06182c; }
    .dark ::-webkit-scrollbar-thumb { background: #296374; }
    .dark ::-webkit-scrollbar-thumb:hover { background: #629FAD; }

    /* ปรับเอฟเฟกต์ Hover ตารางในโหมดมืด */
    .dark #customers-table tr:hover {
      background-color: #296374 !important;
    }
    
    /* 1. บังคับสีข้อความทั่วไปในตารางให้เป็นสีครีมสว่าง (#EDEDCE) */
    .dark table tbody td {
      color: #EDEDCE !important;
    }
    
    /* บังคับสีสำหรับ element ที่ซ้อนอยู่ข้างใน */
    .dark table tbody td button,
    .dark table tbody td span,
    .dark table tbody td i {
      color: #EDEDCE !important;
    }
    
    /* 2. เน้นคอลัมน์ที่ 1 (ID) ให้เป็นสีขาวหนา */
    .dark table tbody td:nth-child(1) {
      color: #EDEDCE !important; 
      font-weight: 800 !important;
    }

    /* 3. แก้ปัญหาช่อง Contact ขั้นเด็ดขาด (อ่านง่าย 100%) */
    .dark table tbody td:nth-child(3) {
      /* ใส่พื้นหลังสีฟ้าจางๆ ให้ช่อง Contact เพื่อให้ตัวหนังสือลอยขึ้นมา */
      background-color: rgba(98, 159, 173, 0.15) !important;
      border-left: 2px solid #629FAD; /* ใส่เส้นขอบซ้ายเล็กๆ ให้ดูมีกรอบ */
    }
    
    /* บังคับตัวหนังสือทุกอย่างในช่อง Contact ให้เป็นสีสว่างสุด */
    .dark table tbody td:nth-child(3),
    .dark table tbody td:nth-child(3) * {
      color: #FFFFFF !important; /* ใช้สีขาวล้วนให้สว่างที่สุด */
      font-weight: 700 !important;
      letter-spacing: 0.5px;
    }
  </style>
  <script src="/js/theme.js"></script>
</head>
<body class="bg-contrast text-primary dark:bg-[#06182c] dark:text-contrast min-h-screen flex overflow-hidden transition-colors duration-300">

  <aside class="w-64 bg-primary text-contrast flex-shrink-0 flex flex-col border-r-4 border-accent hidden md:flex z-20 transition-colors duration-300">
    <div class="h-20 flex items-center justify-center border-b border-secondary">
      <h1 class="text-3xl font-extrabold tracking-tighter uppercase italic">Gym<span class="text-accent">Bro</span></h1>
    </div>
    <nav class="flex-1 overflow-y-auto py-6">
      <ul class="space-y-1">
        <li>
          <a href="/admin/dashboard" class="flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="layout-dashboard" class="w-5 h-5 group-hover:text-accent transition-colors text-accent"></i>
            <span>Dashboard</span>
          </a>
        </li>
        <li>
          <a href="/admin/customers" class="flex items-center gap-4 px-6 py-4 bg-secondary border-l-4 border-accent text-white font-bold uppercase tracking-wide transition-all">
            <i data-lucide="users" class="w-5 h-5"></i>
            <span>Customers</span>
          </a>
        </li>
        <li>
          <a href="/admin/trainers" class="flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="dumbbell" class="w-5 h-5 group-hover:text-accent transition-colors text-accent"></i>
            <span>Trainers</span>
          </a>
        </li>
        <li>
          <a href="/admin/equipments" class="flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="monitor-smartphone" class="w-5 h-5 group-hover:text-accent transition-colors text-accent"></i>
            <span>Equipment</span>
          </a>
        </li>
        <li>
          <a href="/admin/sessions" class="flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="calendar-check" class="w-5 h-5 group-hover:text-accent transition-colors text-accent"></i>
            <span>Sessions</span>
          </a>
        </li>
        <li>
          <a href="/admin/logs" class="flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="file-text" class="w-5 h-5 group-hover:text-accent transition-colors text-accent"></i>
            <span>System Logs</span>
          </a>
        </li>
        <li class="mt-8 border-t border-secondary pt-4">
          <button onclick="logout()" class="w-full text-left flex items-center gap-4 px-6 py-4 text-red-300 hover:bg-red-900/50 hover:text-red-100 font-semibold uppercase tracking-wide transition-all group">
            <i data-lucide="log-out" class="w-5 h-5 group-hover:text-red-400 transition-colors"></i>
            <span>Logout</span>
          </button>
          <button onclick="toggleTheme()" class="w-full text-left flex items-center gap-4 px-6 py-4 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase tracking-wide transition-all group">
            <i id="theme-icon" data-lucide="moon" class="w-5 h-5 group-hover:text-accent transition-colors text-accent"></i>
            <span>Theme</span>
          </button>
        </li>
      </ul>
    </nav>
    <div class="p-4 bg-secondary border-t border-primary">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-accent flex items-center justify-center text-primary font-bold text-lg">AD</div>
        <div>
          <p class="text-sm font-bold text-white">Admin User</p>
          <p class="text-xs text-accent">Manager</p>
        </div>
      </div>
    </div>
  </aside>

  <main class="flex-1 flex flex-col h-screen overflow-hidden relative">
    
    <header class="h-16 bg-primary text-contrast flex items-center justify-between px-4 md:hidden shadow-lg z-10 transition-colors duration-300 border-b border-accent">
      <button id="mobile-menu-btn" class="p-2 hover:bg-secondary text-white">
        <i data-lucide="menu" class="w-6 h-6"></i>
      </button>
      <span class="font-bold uppercase tracking-wider">Customers</span>
      <div class="w-8"></div>
    </header>

    <div id="mobile-sidebar" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden md:hidden">
      <aside class="w-64 h-full bg-primary text-contrast flex flex-col border-r-4 border-accent shadow-2xl transform -translate-x-full transition-transform duration-300" id="mobile-sidebar-content">
        <div class="h-16 flex items-center justify-between px-6 border-b border-secondary">
          <h1 class="text-2xl font-extrabold uppercase italic">Gym<span class="text-accent">Bro</span></h1>
          <button id="close-sidebar-btn" class="text-white hover:text-accent"><i data-lucide="x" class="w-6 h-6"></i></button>
        </div>
        <nav class="flex-1 overflow-y-auto py-4">
          <ul class="space-y-1">
            <li><a href="/admin/dashboard" class="block px-6 py-3 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase">Dashboard</a></li>
            <li><a href="/admin/customers" class="block px-6 py-3 bg-secondary text-white font-bold uppercase border-l-4 border-accent">Customers</a></li>
            <li><a href="/admin/trainers" class="block px-6 py-3 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase">Trainers</a></li>
            <li><a href="/admin/equipments" class="block px-6 py-3 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase">Equipment</a></li>
            <li><a href="/admin/sessions" class="block px-6 py-3 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase">Sessions</a></li>
            <li><a href="/admin/logs" class="block px-6 py-3 text-gray-300 hover:bg-secondary hover:text-white font-semibold uppercase">System Logs</a></li>
            <li><button onclick="logout()" class="block w-full text-left px-6 py-3 text-red-300 hover:bg-red-900/50 hover:text-red-100 font-semibold uppercase">Logout</button></li>
          </ul>
        </nav>
      </aside>
    </div>

    <div class="flex-1 overflow-y-auto p-4 md:p-8 transition-colors duration-300 relative">
      
      <div class="mb-8 border-b-4 border-primary dark:border-accent pb-4">
        <h2 class="text-4xl font-extrabold text-primary dark:text-white uppercase tracking-tighter">Member Management</h2>
        <p class="text-secondary dark:text-accent font-medium mt-1">Add new members and manage existing ones.</p>
      </div>

      <div class="bg-white dark:bg-primary border-2 border-primary dark:border-accent p-6 mb-8 shadow-[4px_4px_0px_0px_#0C2C55] dark:shadow-[4px_4px_0px_0px_#629FAD] transition-all duration-300">
        <h3 class="text-xl font-bold uppercase mb-4 flex items-center gap-2 text-primary dark:text-accent">
          <i data-lucide="user-plus" class="w-5 h-5 text-accent"></i> Add New Member
        </h3>
        <form id="customer-form" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <input id="name" placeholder="Full Name" required class="border-2 border-primary dark:border-secondary p-3 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast placeholder-gray-400">
          <input id="email" placeholder="Email" required type="email" class="border-2 border-primary dark:border-secondary p-3 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast placeholder-gray-400">
          <input id="phone" placeholder="Phone" class="border-2 border-primary dark:border-secondary p-3 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast placeholder-gray-400">
          
          <select id="memberType" required class="border-2 border-primary dark:border-secondary p-3 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast">
            <option value="Standard">Standard</option>
            <option value="Premium">Premium</option>
            <option value="VIP">VIP</option>
          </select>
          
          <select id="memberLevel" required class="border-2 border-primary dark:border-secondary p-3 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast">
            <option value="Basic">Basic</option>
            <option value="Silver">Silver</option>
            <option value="Gold">Gold</option>
          </select>
          
          <div class="flex flex-col">
            <label class="text-xs font-bold uppercase text-secondary dark:text-accent mb-1">Start Date</label>
            <input id="memberStartDate" type="date" required class="border-2 border-primary dark:border-secondary p-2 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast">
          </div>
          
          <div class="flex flex-col">
            <label class="text-xs font-bold uppercase text-secondary dark:text-accent mb-1">End Date</label>
            <input id="memberEndDate" type="date" class="border-2 border-primary dark:border-secondary p-2 font-bold focus:outline-none focus:border-accent dark:focus:border-accent bg-white dark:bg-[#06182c] text-primary dark:text-contrast">
          </div>
          
          <button type="submit" class="bg-primary dark:bg-accent text-contrast dark:text-primary font-bold uppercase hover:bg-secondary dark:hover:bg-contrast hover:shadow-[2px_2px_0px_0px_#629FAD] dark:hover:shadow-[2px_2px_0px_0px_#EDEDCE] transition-all active:translate-y-1 active:shadow-none border-2 border-transparent h-full flex items-center justify-center gap-2">
            <i data-lucide="save" class="w-4 h-4"></i> Save Member
          </button>
        </form>
      </div>

      <div class="mb-4 flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex w-full md:w-auto gap-2">
            <input type="text" id="search-input" placeholder="Search customers..." class="border-2 border-primary dark:border-accent p-2 w-full md:w-64 font-bold text-sm bg-white dark:bg-[#06182c] text-primary dark:text-contrast focus:outline-none focus:border-accent" onkeypress="if(event.key==='Enter') searchCustomers()">
            <button onclick="searchCustomers()" class="bg-primary dark:bg-accent text-contrast dark:text-primary px-4 py-2 font-bold uppercase text-xs hover:bg-secondary dark:hover:bg-contrast transition-colors">Search</button>
        </div>
        <div class="flex items-center gap-2">
            <button id="prev-page" onclick="changePage(-1)" class="bg-white dark:bg-primary border-2 border-primary dark:border-accent px-3 py-1 font-bold uppercase text-xs hover:bg-secondary dark:hover:bg-contrast text-primary dark:text-contrast hover:text-white dark:hover:text-primary transition-colors disabled:opacity-50 disabled:cursor-not-allowed">Prev</button>
            <span id="page-info" class="font-bold text-sm text-primary dark:text-contrast">Page 1 of 1</span>
            <button id="next-page" onclick="changePage(1)" class="bg-white dark:bg-primary border-2 border-primary dark:border-accent px-3 py-1 font-bold uppercase text-xs hover:bg-secondary dark:hover:bg-contrast text-primary dark:text-contrast hover:text-white dark:hover:text-primary transition-colors disabled:opacity-50 disabled:cursor-not-allowed">Next</button>
        </div>
      </div>

      <div class="bg-white dark:bg-primary border-2 border-primary dark:border-accent shadow-[8px_8px_0px_0px_#296374] dark:shadow-[8px_8px_0px_0px_#629FAD] transition-all duration-300">
        <div class="bg-secondary p-4 border-b-2 border-primary dark:border-accent">
          <h3 class="text-xl font-bold text-white dark:text-contrast uppercase tracking-wider flex items-center gap-2">
            <i data-lucide="users" class="w-5 h-5 text-accent"></i> Registered Members
          </h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-gray-100 dark:bg-[#06182c] border-b-2 border-primary dark:border-accent text-primary dark:text-accent text-sm uppercase tracking-wider">
                <th class="p-4 font-extrabold">ID</th>
                <th class="p-4 font-extrabold">Full Name</th>
                <th class="p-4 font-extrabold">Contact</th>
                <th class="p-4 font-extrabold">Membership</th>
                <th class="p-4 font-extrabold">Status</th>
                <th class="p-4 font-extrabold text-center">Actions</th>
              </tr>
            </thead>
            <tbody id="customers-table" class="divide-y-2 divide-gray-100 dark:divide-[#06182c] text-sm font-semibold text-secondary dark:text-contrast bg-white dark:bg-primary">
              </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>

  <script>
    lucide.createIcons();
    // Mobile Sidebar Logic (Same as Index)
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const closeSidebarBtn = document.getElementById('close-sidebar-btn');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const mobileSidebarContent = document.getElementById('mobile-sidebar-content');

    function openSidebar() { mobileSidebar.classList.remove('hidden'); setTimeout(() => mobileSidebarContent.classList.remove('-translate-x-full'), 10); }
    function closeSidebar() { mobileSidebarContent.classList.add('-translate-x-full'); setTimeout(() => mobileSidebar.classList.add('hidden'), 300); }

    if(mobileMenuBtn) mobileMenuBtn.addEventListener('click', openSidebar);
    if(closeSidebarBtn) closeSidebarBtn.addEventListener('click', closeSidebar);
    if(mobileSidebar) mobileSidebar.addEventListener('click', (e) => { if(e.target === mobileSidebar) closeSidebar(); });
  </script>
  <script src="/js/config.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/customers.js"></script>
  <script>
    lucide.createIcons();
  </script>
</body>
</html>